<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="assitant.mapper.UserMapper">

    <select id="findById" resultType="assitant.entity.po.User">
        select * from my_mall.user where id = #{id}
    </select>

    <select id="findByLoginName" resultType="assitant.entity.po.User">
        select * from my_mall.user where login_name = #{loginName}
    </select>

</mapper>
