<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="assitant.mapper.GoodsCategoryMapper">

    <select id="findAll" resultType="assitant.entity.po.GoodsCategory">
        select * from my_mall.goods_category order by `rank`
    </select>

    <select id="findByParentId" resultType="assitant.entity.po.GoodsCategory">
        select * from my_mall.goods_category where parent_id = #{parentId} order by `rank`
    </select>

    <select id="findById" resultType="assitant.entity.po.GoodsCategory">
        select * from my_mall.goods_category where id = #{id}
    </select>

</mapper>